# ==============================================================
# ENEM Study Platform — Variáveis de ambiente
# ==============================================================
# Copie este arquivo para .env e preencha os valores:
#   cp .env.example .env
#   nano .env
# ==============================================================

# --- App ---
APP_NAME=ENEM Studies
# Gere com: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=TROQUE-ISSO-gere-uma-chave-aleatoria

# --- Database ---
DATABASE_URL=sqlite:///./data/enem.db

# --- Cache ---
# Diretório para cache de vídeos (será symlink para SD se disponível)
CACHE_DIR=data/cache
# Limite máximo de cache em GB (LRU remove os mais antigos quando atinge)
CACHE_MAX_GB=50
# Path do SD card (deixe vazio para auto-detectar)
# Exemplo: /storage/1234-5678
SD_CARD_PATH=

# --- Telegram ---
# Obtenha em https://my.telegram.org → API Development Tools
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=sua_hash_aqui
TELEGRAM_PHONE=+5531999999999
# IDs dos grupos/canais com vídeos (separados por vírgula)
# Descubra os IDs rodando: python scripts/setup_telegram.py
TELEGRAM_GROUP_IDS=-1001234567890,-1009876543210
# Quantas mensagens buscar por grupo na sincronização
TELEGRAM_FETCH_LIMIT=3000

# --- Arquivo de menus (mapeamento de tags) ---
MENU_FILE=data/menus/raw_menus.txt

# --- Usuário 1 ---
USER1_NAME=Maria
USER1_EMAIL=maria@email.com
USER1_PASSWORD=senhaForte123

# --- Usuário 2 ---
USER2_NAME=João
USER2_EMAIL=joao@email.com
USER2_PASSWORD=outraSenha456
